# ============================================
# OPSEC — НИКОГДА не должно попасть в репо
# ============================================
# Эти паттерны страхуют от случайной публикации.
# Подробности — в OPSEC_RULES.md.

# Любые env-файлы — даже названные иначе
.env
.env.*
*.env
env.txt
environment.txt

# Файлы с явным указанием на секреты в имени
*secret*
*password*
*token*
*api_key*
*credentials*
*.pem
*.key
*.p12
*.pfx

# Папки с продакшн-ключами (мало ли кто-то случайно скопирует)
KEYS_PRODUCTION/
keys/
secrets/
.keys/

# Дампы баз данных
*.sql
*.dump
*.sqlite
*.sqlite3
*.db

# Конфиги с возможными секретами
config.local.*
settings.local.*

# ============================================
# Системные файлы ОС
# ============================================

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.directory
.Trash-*

# ============================================
# Редакторы и IDE
# ============================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ============================================
# Временные и черновики
# ============================================

# Локальные черновики, которые ещё не готовы к публикации
drafts/
*.draft.md
*.wip.md
TODO.local.md

# Бэкапы редакторов
*.bak
*.backup
*.orig

# ============================================
# Логи и временные дампы
# ============================================

*.log
logs/
tmp/
temp/

# ============================================
# Файлы, специфичные для приватных репо Transkrib
# ============================================
# Если кто-то по ошибке скопирует файл из приватной базы — игнорируем.

# Технические скриншоты с возможными UI с секретами
screenshots/
*.screenshot.png

# Конкретные имена файлов из приватной базы
03_HANDOFF.md
04_SESSIONS_LOG.md
05_KNOWN_BUGS.md
06_INFRASTRUCTURE.md
08_DECISIONS_LOG.md
09_CONTENT_RULES.md
10_TEAM_MODEL.md
BUGS_FIXED.md
CONTENT_GUIDE.md

# Файлы Cursor pr.*
pr.*.txt

# Снапшоты сессий из приватной базы
snapshots/
*-session-end.md
*-session-start.md
